//- layout.jade
doctype html
html(ng-app="netStatsApp", ng-class="{'light-theme': isLightTheme}")
  head
    meta(name="viewport", content="width=device-width, initial-scale=1.0, maximum-scale=1.0")
    title LXP Network Status
    style(type="text/css") [ng\:cloak], [ng-cloak], [data-ng-cloak], [x-ng-cloak], .ng-cloak, .x-ng-cloak { display: none !important; }
    link(rel='stylesheet', href='//fonts.googleapis.com/css?family=Source+Sans+Pro:200,300,400,600,700')
    link(rel='stylesheet', href='/css/netstats.min.css')
    style.
      .navbar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .navbar-brand .logo {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 18px;
        color: #000;
      }
      .navbar-brand .brand-text {
        font-weight: 700;
        font-size: 18px;
        color: #f59e0b;
        letter-spacing: 2px;
      }
      .theme-toggle {
        cursor: pointer;
        padding: 8px 12px;
        border-radius: 4px;
        background: rgba(255,255,255,0.1);
        color: #fff;
        border: none;
        font-size: 16px;
        transition: all 0.3s ease;
      }
      .theme-toggle:hover {
        background: rgba(255,255,255,0.2);
      }
      .navbar-right-controls {
        float: right;
        margin-top: 8px;
        display: flex;
        gap: 10px;
        align-items: center;
      }
  body
    nav.navbar.navbar-default
      div.container-fluid
        div.navbar-header
          a.navbar-brand(href='/')
            img.logo-img(src='/images/lxp-logo.png', alt='LXP Logo', style='height: 40px; width: auto; margin-right: 10px;')
            span.brand-text LXP NETWORK
        div.navbar-right-controls(ng-controller='ThemeCtrl')
          button.theme-toggle(ng-click='toggleTheme()', title='Toggle theme')
            i(ng-class="isLightTheme ? 'icon-bulb' : 'icon-moon'")
    block content

    script(src="/js/netstats.min.js")